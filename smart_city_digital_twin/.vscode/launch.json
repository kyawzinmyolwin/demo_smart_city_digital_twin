{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python3"
        },
        {
            "name": "traffic_counts_parser (.venv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/2D_simulation/scripts/traffic_counts_parser.py",
            "cwd": "${workspaceFolder}/2D_simulation",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python3"
        }
    ]
}
